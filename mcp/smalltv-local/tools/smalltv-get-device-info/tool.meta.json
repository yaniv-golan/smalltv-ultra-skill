{
  "name": "smalltv-get-device-info",
  "description": "Verify device connectivity and identity. Call this FIRST in every session before using any other tool. Returns model name and firmware version from /v.json. Read-only and safe.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "device_ip": {
        "type": "string",
        "description": "Optional device IP. Falls back to SMALLTV_DEVICE_IP."
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "required": ["success"],
    "properties": {
      "success": {
        "type": "boolean"
      },
      "result": {
        "type": "object",
        "required": ["device_ip", "endpoint", "body"],
        "properties": {
          "device_ip": { "type": "string" },
          "endpoint": { "type": "string" },
          "body": { "type": "object" }
        }
      },
      "error": {
        "type": "object",
        "required": ["type", "message"],
        "properties": {
          "type": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  },
  "timeoutSecs": 10,
  "annotations": {
    "readOnlyHint": true,
    "destructiveHint": false
  }
}
